# IP público da VPS (obrigatório)
VPS_PUBLIC_IP=1.2.3.4

# Interface de rede pública da VPS
# Descubra com: ip route get 8.8.8.8 | awk '{print $5; exit}'
NET_IFACE=eth0

# Porta WireGuard (padrão: 51820)
WG_PORT=51820

# Porta do painel web (padrão: 8080)
WEB_PORT=8080

# Interface WireGuard (padrão: wg0)
WG_IFACE=wg0
